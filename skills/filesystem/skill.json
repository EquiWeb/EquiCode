{
  "name": "filesystem",
  "version": "0.1.0",
  "description": "Read/write/list files within the workspace.",
  "schema": {
    "tools": [
      {
        "name": "filesystem.read",
        "input_schema": {
          "type": "object",
          "properties": {
            "path": { "type": "string" }
          },
          "required": ["path"]
        }
      },
      {
        "name": "filesystem.list",
        "input_schema": {
          "type": "object",
          "properties": {
            "path": { "type": "string" }
          },
          "required": ["path"]
        }
      },
      {
        "name": "filesystem.write",
        "input_schema": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "content": { "type": "string" },
            "append": { "type": "boolean" }
          },
          "required": ["path", "content"]
        }
      },
      {
        "name": "filesystem.grep",
        "input_schema": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "pattern": { "type": "string" },
            "case_sensitive": { "type": "boolean" }
          },
          "required": ["path", "pattern"]
        }
      }
    ]
  },
  "entrypoint": {
    "type": "subprocess",
    "command": "./run.sh"
  }
}
